{
  "name": "mise-en-place",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:prisma\" \"npm run dev:next\"",
    "dev:next": "next dev",
    "dev:prisma": "prisma dev",
    "build": "prisma db push && next build",
    "start": "next start",
    "env:pull": "vercel env pull .env.local && cp .env.local .env",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "MOCK_AUTH=true playwright test",
    "test:e2e:ui": "MOCK_AUTH=true playwright test --ui",
    "prepare": "husky",
    "postinstall": "prisma generate"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^6.1.0",
    "ai": "^6.0.184",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pdf2json": "^4.0.3",
    "prisma": "^6.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.5",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.21.0",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.4.3",
    "msw": "^2.14.6",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.0.9",
    "ts-node": "^10.9.2",
    "typescript": "5.7.3",
    "vercel": "^54.0.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vitest-fetch-mock": "^0.4.4"
  },
  "overrides": {
    "undici": "^7.0.0",
    "tar": "^7.5.10",
    "minimatch": "^10.2.2",
    "path-to-regexp": "^8.3.0",
    "smol-toml": "^1.6.1",
    "@tootallnate/once": "^3.0.1",
    "srvx": "^0.11.13",
    "ajv": "^8.17.1",
    "@eslint/eslintrc": {
      "ajv": "^6.12.6"
    },
    "eslint": {
      "ajv": "^6.12.6"
    },
    "cross-spawn": "^7.0.5",
    "nanoid": "^3.3.8",
    "cookie": "^0.7.0",
    "postcss": "^8.5.10"
  }
}
