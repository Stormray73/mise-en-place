generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String               @id @default(cuid())
  name            String?
  email           String?              @unique
  emailVerified   DateTime?
  image           String?
  accounts        Account[]
  prepCompletions PrepCompletion[]
  recipes         Recipe[]
  sessions        Session[]
  pantryItems     PantryItem[]
  ingredients     Ingredient[]
  tags            Tag[]
  mealPlan        MealPlan?
  manualShopping  ManualShoppingItem[]
  pantryLocations PantryLocation[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Recipe {
  id               String            @id @default(cuid())
  title            String
  yieldAmount      Float
  yieldUnit        String
  manualMacros     Json?
  userId           String
  isFavorite       Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  servings         Int?
  plannedRecipes   PlannedRecipe[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComponents RecipeComponent[] @relation("ChildRecipe")
  components       RecipeComponent[] @relation("ParentRecipe")
  steps            RecipeStep[]
  tags             Tag[]
}

model Tag {
  id      String   @id @default(cuid())
  name    String
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipes Recipe[]

  @@unique([name, userId])
}

model RecipeStep {
  id             String @id @default(cuid())
  order          Int
  instruction    String
  timerInSeconds Int?
  recipeId       String
  recipe         Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Ingredient {
  id           String            @id @default(cuid())
  name         String
  usdaId       String?           @unique
  baseMacros   Json?
  baseAmount   Float?
  foodPortions Json?
  userId       String?
  components   RecipeComponent[]
  pantryItems  PantryItem[]
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PantryItem {
  id               String          @id @default(cuid())
  userId           String
  ingredientId     String
  quantity         Float
  unit             String
  locationId       String?
  restockThreshold Float           @default(0)
  packageQuantity  Float?          @default(1)
  packageSize      Float?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  ingredient       Ingredient      @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  location         PantryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
}

model PantryLocation {
  id          String       @id @default(cuid())
  userId      String
  name        String
  pantryItems PantryItem[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([name, userId])
}

model RecipeComponent {
  id            String      @id @default(cuid())
  quantity      Float
  unit          String
  recipeId      String
  ingredientId  String?
  childRecipeId String?
  prepState     String?
  childRecipe   Recipe?     @relation("ChildRecipe", fields: [childRecipeId], references: [id])
  ingredient    Ingredient? @relation(fields: [ingredientId], references: [id])
  recipe        Recipe      @relation("ParentRecipe", fields: [recipeId], references: [id], onDelete: Cascade)
}

model MealPlan {
  id        String   @id @default(cuid())
  name      String?
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  meals     Meal[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Meal {
  id             String          @id @default(cuid())
  date           DateTime
  slot           String
  mealPlanId     String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sortOrder      Int             @default(0)
  mealPlan       MealPlan        @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  plannedRecipes PlannedRecipe[]
}

model PlannedRecipe {
  id                    String           @id @default(cuid())
  mealId                String
  recipeId              String
  scale                 Float            @default(1.0)
  prepState             String?
  isLeftoverSource      Boolean          @default(false)
  sourcePlannedRecipeId String?
  excludeFromPrep       Boolean          @default(false)
  meal                  Meal             @relation(fields: [mealId], references: [id], onDelete: Cascade)
  recipe                Recipe           @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  sourcePlannedRecipe   PlannedRecipe?   @relation("Leftovers", fields: [sourcePlannedRecipeId], references: [id])
  consumedLeftovers     PlannedRecipe[]  @relation("Leftovers")
  prepCompletions       PrepCompletion[]
}

model PrepCompletion {
  id              String         @id @default(cuid())
  plannedRecipeId String?
  ingredientId    String?
  childRecipeId   String?
  completed       Boolean        @default(false)
  userId          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  plannedRecipe   PlannedRecipe? @relation(fields: [plannedRecipeId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ManualShoppingItem {
  id          String   @id @default(cuid())
  userId      String
  name        String
  quantity    Float    @default(1.0)
  unit        String?
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
