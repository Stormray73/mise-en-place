generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accounts        Account[]
  mealPlans       MealPlan[]
  prepCompletions PrepCompletion[]
  recipes         Recipe[]
  sessions        Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Recipe {
  id               String            @id @default(cuid())
  title            String
  yieldAmount      Float
  yieldUnit        String
  manualMacros     Json?
  userId           String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  servings         Int?
  plannedRecipes   PlannedRecipe[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComponents RecipeComponent[] @relation("ChildRecipe")
  components       RecipeComponent[] @relation("ParentRecipe")
  steps            RecipeStep[]
}

model RecipeStep {
  id             String @id @default(cuid())
  order          Int
  instruction    String
  timerInSeconds Int?
  recipeId       String
  recipe         Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Ingredient {
  id         String            @id @default(cuid())
  name       String
  usdaId     String?           @unique
  baseMacros Json?
  baseAmount Float?
  components RecipeComponent[]
}

model RecipeComponent {
  id            String      @id @default(cuid())
  quantity      Float
  unit          String
  recipeId      String
  ingredientId  String?
  childRecipeId String?
  prepState     String?
  childRecipe   Recipe?     @relation("ChildRecipe", fields: [childRecipeId], references: [id])
  ingredient    Ingredient? @relation(fields: [ingredientId], references: [id])
  recipe        Recipe      @relation("ParentRecipe", fields: [recipeId], references: [id], onDelete: Cascade)
}

model MealPlan {
  id        String   @id @default(cuid())
  name      String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  meals     Meal[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Meal {
  id             String          @id @default(cuid())
  date           DateTime
  slot           String
  mealPlanId     String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  mealPlan       MealPlan        @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  plannedRecipes PlannedRecipe[]
}

model PlannedRecipe {
  id                    String           @id @default(cuid())
  mealId                String
  recipeId              String
  scale                 Float            @default(1.0)
  prepState             String?
  isLeftoverSource      Boolean          @default(false)
  sourcePlannedRecipeId String?
  meal                  Meal             @relation(fields: [mealId], references: [id], onDelete: Cascade)
  recipe                Recipe           @relation(fields: [recipeId], references: [id])
  sourcePlannedRecipe   PlannedRecipe?   @relation("LeftoverRelation", fields: [sourcePlannedRecipeId], references: [id])
  consumedLeftovers     PlannedRecipe[]  @relation("LeftoverRelation")
  prepCompletions       PrepCompletion[]
}

model PrepCompletion {
  id              String         @id @default(cuid())
  plannedRecipeId String?
  ingredientId    String?
  childRecipeId   String?
  completed       Boolean        @default(false)
  userId          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  plannedRecipe   PlannedRecipe? @relation(fields: [plannedRecipeId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}
